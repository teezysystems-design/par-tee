{
  "expo": {
    "name": "Teezy",
    "slug": "teezy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "teezy",
    "description": "Book golf tee times based on your mood. Find courses that match how you want to play.",
    "keywords": ["golf", "tee time", "booking", "mood"],
    "privacy": "https://teezy.app/privacy",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a6b2a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.teezy.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.teezy.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a6b2a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-location"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
