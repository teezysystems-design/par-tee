{
  "name": "@teezy/api",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.10.0",
    "@hono/zod-validator": "^0.2.0",
    "@supabase/supabase-js": "^2.41.0",
    "@teezy/db": "*",
    "@teezy/shared": "*",
    "drizzle-orm": "^0.30.0",
    "hono": "^4.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
